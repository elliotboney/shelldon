# shelldon configuration — copy to `.env` and fill in the blanks.
#   cp .env.example .env   (then edit)
# `.env` is gitignored (it holds secrets). The systemd service reads it via EnvironmentFile.

# --- LLM brain ---------------------------------------------------------------
# GLM via Z.ai (Anthropic-compatible) is the default. GLM_API_KEY is your Z.ai key.
GLM_API_KEY=
GLM_MODEL=glm-4.7
# GLM_BASE_URL=https://api.z.ai/api/anthropic   # default; override for a different endpoint
# PROVIDER_CHAIN=glm                             # ordered fallback, e.g. "glm,ollama,groq"
# OLLAMA_API_BASE=http://your-lan-box:11434      # if using a local model in the chain

# --- Telegram transport (when SHELLDON_TRANSPORT=telegram) -------------------
# Create a bot with @BotFather, paste its token here. shelldon's OWN var, so it
# never collides with a v1 that uses TELEGRAM_BOT_TOKEN.
SHELLDON_TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user ids allowed to talk to the pet (the security gate).
ALLOWED_USERS=
# ALLOW_ALL_USERS=false    # set true to let anyone message it (not recommended)

# --- Proactive check-in ------------------------------------------------------
# The pet messages you on its own every few hours (bounded by its daily budget).
# Quiet hours suppress those overnight pings (owner-LOCAL time). Default 22:00-07:00.
# SHELLDON_QUIET_HOURS=22:00-07:00   # custom window (HH:MM-HH:MM, may cross midnight)
# SHELLDON_QUIET_HOURS=off           # disable quiet hours (allow 24/7 proactive pings)
